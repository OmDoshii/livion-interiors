# ──────────────────────────────────────────────────────────
# Livion Interiors — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git
# ──────────────────────────────────────────────────────────

# ─── Database (Supabase) ───────────────────────────────────
# Get from: Supabase → Project Settings → Database → Connection string → URI
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Cloudinary (Image Uploads) ────────────────────────────
# Get from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Admin Auth (JWT) ─────────────────────────────────────
# Any long random string — generate at: https://randomkeygen.com
JWT_SECRET=your_long_random_jwt_secret_here

# ─── WhatsApp Cloud API ────────────────────────────────────
# Get from: developers.facebook.com → Your App → WhatsApp
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token
TEAM_WHATSAPP_NUMBER=919XXXXXXXXX

# ─── SendGrid (Email) ─────────────────────────────────────
# Get from: sendgrid.com → Settings → API Keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=leads@livioninteriors.com
TEAM_EMAIL=your@email.com

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
