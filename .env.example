# ──────────────────────────────────────────────────────────
# Livion Interiors — Environment Variables
# Copy this to .env.local and fill in your actual values
# NEVER commit .env.local to git
# ──────────────────────────────────────────────────────────

# ─── Database ─────────────────────────────────────────────
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/livion_interiors

# ─── WhatsApp Cloud API ────────────────────────────────────
# Get these from: https://developers.facebook.com/
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id_here
WHATSAPP_ACCESS_TOKEN=your_permanent_access_token_here
TEAM_WHATSAPP_NUMBER=919XXXXXXXXX   # Team's WA number for internal alerts (with 91)

# ─── SendGrid ─────────────────────────────────────────────
# Get from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxx
FROM_EMAIL=leads@livioninteriors.com
TEAM_EMAIL=nimitesh@livioninteriors.com

# ─── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
